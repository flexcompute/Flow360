{
    "boundaries": {
        "outerBlock/farfield": {
            "type": "Freestream"
        }
    },
    "freestream": {
        "Mach": 0.0,
        "MachRef": 0.1,
        "Temperature": 288.15,
        "alphaAngle": 0.0,
        "betaAngle": 0.0,
        "muRef": 1e-05
    },
    "geometry": {
        "refArea": 1.0
    },
    "heatEquationSolver": {
        "equationEvalFrequency": 20,
        "linearSolver": {
            "absoluteTolerance": 1e-12,
            "maxIterations": 4
        },
        "modelType": "HeatEquation"
    },
    "navierStokesSolver": {
        "equationEvalFrequency": 1,
        "linearIterations": 50,
        "modelType": "Compressible",
        "numericalDissipationFactor": 0.01,
        "orderOfAccuracy": 2
    },
    "surfaceOutput": {
        "surfaces": {
            "outerBlock/Interface_innerBlock": {
                "outputFields": [
                    "T"
                ]
            }
        }
    },
    "timeStepping": {
        "maxPseudoSteps": 1,
        "physicalSteps": 1,
        "timeStepSize": "inf"
    },
    "turbulenceModelSolver": {
        "modelType": "None"
    },
    "volumeOutput": {
        "outputFields": [
            "solutionNavierStokes",
            "T",
            "primitiveVars"
        ],
        "outputFormat": "paraview"
    },
    "volumeZones": {
        "innerBlock": {
            "initialCondition": {
                "T": 1
            },
            "modelType": "HeatEquation",
            "thermalConductivity": 0.03472
        },
        "outerBlock": {
            "modelType": "FluidDynamics"
        }
    }
}
