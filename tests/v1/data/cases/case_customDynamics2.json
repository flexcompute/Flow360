        "fluid/periodic_0_r": {
            "type": "SlipWall"
        },
        "fluid/wall": {
            "type": "NoSlipWall"
        }
    },
    "freestream": {
        "Mach": 0.5,
        "Reynolds": "inf",
        "Temperature": -1,
        "alphaAngle": 3.12,
        "betaAngle": 0.0
    },
    "geometry": {
        "endianness": "big",
        "meshName": "file.cgns",
        "momentCenter": [
            1325.9,
            468.75,
            177.95
        ],
        "momentLength": [
            275.8,
            275.8,
            275.8
        ],
        "refArea": 297360.0
    },
    "initialCondition": {
        "constants": {
            "Cp": "1./(1.4-1.)",
            "P_inf": "1/1.4",
            "Radius": "1.",
            "Rgas": "1./1.4",
            "T_inf": "1.0",
            "U_inf": "0.5",
            "Xc": "0.",
            "Yc": "0.",
            "beta": "1./5."
        },
        "p": "P_inf/(Rgas*T_inf)*pow((T_inf-(U_inf^2*beta^2)/(2*Cp)*exp(-((x-Xc)^2+(y-Yc)^2)/(Radius*Radius)))/T_inf,1/(1.4-1.)) * Rgas * (T_inf-(U_inf^2*beta^2)/(2*Cp)*exp(-((x-Xc)^2+(y-Yc)^2)/(Radius*Radius)))",
        "rho": "P_inf/(Rgas*T_inf)*pow((T_inf-(U_inf^2*beta^2)/(2*Cp)*exp(-((x-Xc)^2+(y-Yc)^2)/(Radius*Radius)))/T_inf,1/(1.4-1.))",
        "type": "expression",
        "u": "U_inf*(1.-beta*(y-Yc)/Radius*exp(-0.5*((x-Xc)^2+(y-Yc)^2)/(Radius*Radius)))",
        "v": "U_inf*beta*(x-Xc)/Radius*exp(-0.5*((x-Xc)^2+(y-Yc)^2)/(Radius*Radius))",
        "w": "0."
    },
    "navierStokesSolver": {
        "kappaMUSCL": -1.0,
        "linearIterations": 25,
        "tolerance": 1e-09
    },
    "runControl": {
        "restart": false
    },
    "sliceOutput": {
        "outputFormat": "paraview",
        "slices": [
            {
                "sliceName": "sliceTest",
                "sliceNormal": [
                    0.0,
