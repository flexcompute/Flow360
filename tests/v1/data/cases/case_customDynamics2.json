                    0.0
                ],
                "sliceOrigin": [
                    0.7165,
                    0.27772,
                    0.0179426
                ]
            }
        ]
    },
    "surfaceOutput": {
        "Cf": false,
        "CfVec": false,
        "Cp": true,
        "Mach": true,
        "outputFormat": "paraview",
        "primitiveVars": true,
        "wallDistance": false,
        "yPlus": false
    },
    "timeStepping": {
        "CFL": {
            "final": 200,
            "initial": 5,
            "rampSteps": 20
        },
        "maxPseudoSteps": 20,
        "physicalSteps": 1,
        "timeStepSize": 0.25
    },
    "turbulenceModelSolver": {
        "kappaMUSCL": -1.0,
        "linearIterations": 15,
        "modelType": "None",
        "tolerance": 1e-08
    },
    "userDefinedDynamics": [
        {
            "constants": {
                "CLTarget": 0.4,
                "Ki": 0.002,
                "Kp": 0.2
            },
            "inputBoundaryPatches": [
                "fluid/wall"
            ],
            "inputVars": [
                "CL"
            ],
            "outputVars": {
                "alphaAngle": "if (pseudoStep > 500) state[0]; else alphaAngle;"
            },
            "stateVarsInitialValue": [
                "alphaAngle",
                "0.0"
            ],
            "updateLaw": [
                "if (pseudoStep > 500) state[0] + Kp * (CLTarget - CL) + Ki * state[1]; else state[0];",
                "if (pseudoStep > 500) state[1] + (CLTarget - CL); else state[1];"
            ]
        }
    ],
    "volumeOutput": {
        "Cp": false,
        "T": true,
        "mut": false,
        "mutRatio": false,
        "outputFormat": "paraview",
        "primitiveVars": true,
        "residualNavierStokes": true,
        "residualTurbulence": true,
        "s": false,
        "vorticity": true
    }
